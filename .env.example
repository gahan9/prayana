# ──────────────────────────────────────────────────────────────────────────────
# Environment Variables Template
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local or any file with real secrets.
# ──────────────────────────────────────────────────────────────────────────────

# Firebase Web App Configuration
# Obtain from: Firebase Console → Project Settings → Your Apps
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# App URL (used for health checks, OG meta tags, etc.)
NEXT_PUBLIC_APP_URL=https://your_project_id.web.app

# GitHub Actions repository variables (for backend connector checks)
BACKEND_PRODUCTION_HEALTH_URL=https://your_project_id.web.app
BACKEND_STAGING_HEALTH_URL=https://your_project_id--staging.web.app

# GitHub Actions secrets required for deployment
# FIREBASE_TOKEN=your_firebase_ci_token

# Optional: Firebase Emulator flag (set to "true" for local development)
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=false
