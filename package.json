{
  "name": "prayana",
  "version": "1.0.0",
  "description": "Travel Planning and Experience – a mobile & desktop-friendly Firebase web app",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "firebase:emulators": "firebase emulators:start",
    "firebase:deploy": "firebase deploy",
    "firebase:deploy:hosting": "firebase deploy --only hosting",
    "firebase:deploy:rules": "firebase deploy --only firestore:rules,storage:rules",
    "analyze": "ANALYZE=true next build"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "firebase": "^10.12.2",
    "next": "^14.2.5",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^14.2.5",
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.19",
    "eslint": "^10.3.0",
    "eslint-config-next": "^16.2.6",
    "jest": "^30.4.0",
    "jest-environment-jsdom": "^30.4.0",
    "postcss": "^8.4.39",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gahan9/prayana.git"
  },
  "license": "MIT",
  "author": "Gahan Saraiya"
}
