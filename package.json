{
  "name": "prayana",
  "version": "1.0.0",
  "description": "Travel Planning and Experience – a mobile & desktop-friendly Firebase web app",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:rapid": "concurrently \"npm run dev\" \"npm run firebase:emulators\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "test:sanity": "jest --testPathPatterns='__tests__/.*\\.test\\.' --passWithNoTests",
    "test:perf": "jest --testPathPatterns='__tests__/.*\\.perf\\.test\\.' --passWithNoTests",
    "test:concurrency": "jest --testPathPatterns='__tests__/.*\\.concurrency\\.test\\.' --passWithNoTests",
    "test:security": "jest --testPathPatterns='__tests__/.*\\.security\\.test\\.' --passWithNoTests",
    "test:extended": "jest --testPathPatterns='__tests__/.*\\.(test|perf\\.test|concurrency\\.test)\\.' --passWithNoTests",
    "test:full": "jest --passWithNoTests",
    "test:watch": "jest --testPathPatterns='__tests__/.*\\.test\\.' --watch",
    "test:coverage": "jest --testPathPatterns='__tests__/.*\\.test\\.' --coverage",
    "firebase:emulators": "firebase emulators:start",
    "firebase:deploy": "firebase deploy",
    "firebase:deploy:hosting": "firebase deploy --only hosting",
    "firebase:deploy:rules": "firebase deploy --only firestore:rules,storage:rules",
    "analyze": "ANALYZE=true next build"
  },
  "dependencies": {
    "@google-cloud/bigquery": "^8.3.0",
    "@google-cloud/vertexai": "^1.12.0",
    "@google/generative-ai": "^0.24.1",
    "@googlemaps/js-api-loader": "^2.0.2",
    "dotenv": "^17.4.2",
    "firebase": "^10.12.2",
    "jspdf": "^4.2.1",
    "next": "^14.2.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.6",
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/google.maps": "^3.64.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "autoprefixer": "^10.4.19",
    "concurrently": "^9.2.1",
    "esbuild": "^0.28.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "jest": "^30.4.0",
    "jest-environment-jsdom": "^30.4.0",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": "20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gahan9/prayana.git"
  },
  "license": "MIT",
  "author": "Gahan Saraiya"
}
